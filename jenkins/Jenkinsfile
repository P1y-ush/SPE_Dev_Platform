pipeline {
    agent any

    environment {
        STACK = "flask"
        USER = "test"
        IMAGE_NAME = "p1yush123/${STACK}-env"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Clone Repo') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/P1y-ush/SPE_Dev_Platform.git'
            }
        }
 
        //  ANSIBLE (SAFE VERSION)
        stage('Setup Infra (Ansible)') {
            steps {
                sh '''
                echo "Running Ansible setup..."

                # ensure docker running
                sudo systemctl start docker || true
                sudo chmod 666 /var/run/docker.sock || true

                # run ansible but don't fail pipeline
                ansible-playbook ansible/setup.yml || true
                '''
            }
        }

        // FIXED PYTHON ENV (NO PIP BUG)
        stage('Setup Backend Environment') {
            steps {
                dir('backend') {
                    sh '''
                    python3 -m venv venv

                    # REINSTALL CLEAN PIP (Generic fix for environment issues)
                    venv/bin/python -m pip install --upgrade pip || curl -sS https://bootstrap.pypa.io/get-pip.py | venv/bin/python

                    # INSTALL REQUIREMENTS
                    venv/bin/pip install -r requirements.txt
                    '''
                }
            }
        }
        stage('Run Unit Tests') {
            steps {
                dir('backend') {
                    sh '''
                    # Install pytest if not present
                    ./venv/bin/pip install pytest
                    
                    # Run the professional test suite
                    echo "🧪 Running Python Unit Tests..."
                    ./venv/bin/python -m pytest tests/test_api.py -v
                    '''
                }
            }
        }

        stage('Start ELK Monitoring') {
            steps {
                sh '''
                # Preserve vault to keep the data, only cleanup others
                docker rm -f elasticsearch logstash kibana || true
                
                # Ensure vault is running without wiping it
                if ! docker ps | grep vault > /dev/null; then
                    docker-compose up -d vault
                fi
                docker-compose up -d elasticsearch logstash kibana
                '''
            }
        }

        stage('Ensure Mongo Ready') {
            steps {
                sh '''
                # Run cluster commands securely as your local user to bypass folder lockouts
                sudo -u piyush bash -ec "
                    minikube status || minikube start --driver=docker

                    kubectl get namespace dev-platform || kubectl create namespace dev-platform
                    minikube addons list | grep metrics-server | grep enabled || minikube addons enable metrics-server

                    kubectl apply -f k8s/config.yml
                    kubectl apply -f k8s/secrets.yml
                    kubectl apply -f k8s/mongo.yaml
                "

                for i in {1..30}
                do
                    status=$(sudo -u piyush kubectl get pods -n dev-platform -l app=mongo -o jsonpath="{.items[0].status.phase}" 2>/dev/null || echo "NotReady")

                    if [ "$status" = "Running" ]
                    then
                        echo "Mongo ready"
                        break
                    fi

                    sleep 3
                done

                sudo -u piyush pkill -f "kubectl port-forward" || true

                sudo -u piyush JENKINS_NODE_COOKIE=dontKillMe bash -c "nohup kubectl port-forward svc/mongo-svc 27017:27017 -n dev-platform > /tmp/mongo.log 2>&1 &"
                sleep 5
                '''
            }
        }

        stage('Start & Test Backend') {
            steps {
                dir('backend') {
                    sh '''
                    if sudo lsof -Pi :5002 -sTCP:LISTEN -t > /dev/null ; then
                        echo "⚠️ Port 5002 busy, killing old backend..."
                        sudo fuser -k 5002/tcp || true
                        sleep 5
                    fi
                    
                    echo "🚀 Starting Backend as Persistent Process..."
                    sudo -E -u piyush JENKINS_NODE_COOKIE=dontKillMe bash -c "nohup ./venv/bin/python app.py > /tmp/backend.log 2>&1 &"
                    
                    echo "⌛ Waiting 20s for backend stabilization..."
                    sleep 20
                    
                    # Core health check
                    echo "🔍 Verifying Backend Health..."
                    curl -s -f http://localhost:5002/ || (echo "❌ Backend failed to start! Check /tmp/backend.log" && cat /tmp/backend.log && exit 1)
                    echo "✅ Backend is UP and responding."
                    '''
                }
            }
        }

        stage('Build & Push All Images') {
            steps {
                sh '''
                # SECURE STORAGE: Fetching from Vault
                echo " Fetching Docker Hub credentials..."
                DOCKER_PW=$(sudo docker exec -e VAULT_TOKEN=root vault vault kv get -field=password secret/docker-hub)
                
                if [ -z "$DOCKER_PW" ]; then
                    echo " Failed to fetch password from Vault container!"
                    exit 1
                fi
                echo " Credentials retrieved successfully."
                echo "$DOCKER_PW" | docker login -u p1yush123 --password-stdin
                
                # Portable loop for all 4 stacks
                for stack in flask java mern ml; do
                    echo "--- Building and Pushing: $stack ---"
                    docker build -t "p1yush123/${stack}-env:latest" "templates/${stack}"
                    docker push "p1yush123/${stack}-env:latest"
                done
                '''
            }
        }

        stage('Security Scan (Trivy)') {//
            steps {
                sh '''
                echo "--- Initiating Security Audit (Trivy) ---"
                for stack in flask java mern ml; do
                    echo "Scanning Image: p1yush123/${stack}-env:latest"
                    trivy image --severity HIGH,CRITICAL --no-progress "p1yush123/${stack}-env:latest" || true
                done
                '''
            }
        }


        stage('Deploy') {
            steps {
                sh '''
                echo "🚀 Deploying Dashboard Environment..."
                curl -X POST http://localhost:5002/create-env \
                -H "Content-Type: application/json" \
                -d '{"stack":"flask","user":"prod_user","image":"p1yush123/flask-env:latest"}'
                '''
            }
        }
    }

    post {
        success {
            echo "SUCCESS "
        }
        failure {
            echo "FAILED "
        }
    }
}
