pipeline {
    agent any

    environment {
        USER = "test"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Clone Repo') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/P1y-ush/SPE_Dev_Platform.git'
            }
        }
 
        stage('Start ELK Monitoring') {
            steps {
                sh '''
                # Preserve vault to keep the data, only cleanup others
                docker rm -f elasticsearch logstash kibana || true
                
                # Ensure vault is running without wiping it
                if ! docker ps | grep vault > /dev/null; then
                    docker-compose up -d vault
                fi
                docker-compose up -d elasticsearch logstash kibana
                '''
            }
        }

        stage('Ensure Mongo Ready') {
            steps {
                sh '''
                # Run cluster commands securely as your local user to bypass folder lockouts
                sudo -u piyush bash -ec "
                    minikube status || minikube start --driver=docker

                    kubectl get namespace dev-platform || kubectl create namespace dev-platform
                    minikube addons list | grep metrics-server | grep enabled || minikube addons enable metrics-server

                    kubectl apply -f k8s/config.yml
                    kubectl apply -f k8s/secrets.yml
                    kubectl apply -f k8s/mongo.yaml
                "

                for i in {1..30}
                do
                    status=$(sudo -u piyush kubectl get pods -n dev-platform -l app=mongo -o jsonpath="{.items[0].status.phase}" 2>/dev/null || echo "NotReady")

                    if [ "$status" = "Running" ]
                    then
                        echo "Mongo ready"
                        break
                    fi

                    sleep 3
                done
                '''
            }
        }

        stage('Build & Push All Images') {
            steps {
                sh '''
                # SECURE STORAGE: Fetching from Vault
                echo "Fetching Docker Hub credentials..."
                DOCKER_PW=$(sudo docker exec -e VAULT_TOKEN=root vault vault kv get -field=password secret/docker-hub)
                
                if [ -z "$DOCKER_PW" ]; then
                    echo "Failed to fetch password from Vault container!"
                    exit 1
                fi
                echo "Credentials retrieved successfully."
                echo "$DOCKER_PW" | docker login -u p1yush123 --password-stdin
                
                # Portable loop for all 4 stacks
                for stack in flask java mern ml; do
                    echo "--- Building and Pushing: $stack ---"
                    docker build -t "p1yush123/${stack}-env:latest" "templates/${stack}"
                    docker push "p1yush123/${stack}-env:latest"
                done
                
                # Build and push Backend
                echo "--- Building and Pushing Backend ---"
                docker build -t "p1yush123/spe-backend:latest" "backend"
                docker push "p1yush123/spe-backend:latest"
                '''
            }
        }

        stage('Security Scan (Trivy)') {
            steps {
                sh '''
                echo "--- Initiating Security Audit (Trivy) ---"
                for stack in flask java mern ml; do
                    echo "Scanning Image: p1yush123/${stack}-env:latest"
                    trivy image --severity HIGH,CRITICAL --no-progress "p1yush123/${stack}-env:latest" || true
                done
                
                echo "Scanning Backend Image..."
                trivy image --severity HIGH,CRITICAL --no-progress "p1yush123/spe-backend:latest" || true
                '''
            }
        }

        stage('Deploy Backend') {
            steps {
                sh '''
                echo "Deploying Backend to Kubernetes..."
                sudo -u piyush bash -ec "
                    kubectl apply -f k8s/backend.yaml
                    kubectl rollout restart deployment backend -n dev-platform
                "
                
                echo "Waiting for backend pod to be ready..."
                for i in {1..30}
                do
                    status=$(sudo -u piyush kubectl get pods -n dev-platform -l app=backend -o jsonpath="{.items[0].status.phase}" 2>/dev/null || echo "NotReady")
                    if [ "$status" = "Running" ]
                    then
                        echo "Backend ready"
                        break
                    fi
                    sleep 3
                done
                '''
            }
        }
    }

    post {
        success {
            echo "SUCCESS ✅"
        }
        failure {
            echo "FAILED ❌"
        }
    }
}
